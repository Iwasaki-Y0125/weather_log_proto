<div class="bg-neutral-300 relative w-full h-screen overflow-hidden">
  <div class="px-8">
    <h2 class="text-lg text-gray-700 font-medium my-8">ゆらぎ記録</h2>

    <div data-controller="mood-selector" class="max-w-2xl mx-auto p-6">
      <%= form_with model: @diary, local: true, class: "diary-mood-form" do |form| %>

        <h3 class="text-ms text-gray-700 mb-2">今の気分の調子は？ <span class="text-red-700">*必須</span></h3>

        <div class="grid grid-cols-5 gap-4 mb-6 max-w-sm">
          <% [
            { value: 1, key: "very_good", bg: "bg-blue-100" },
            { value: 2, key: "good", bg: "bg-green-100" },
            { value: 3, key: "neutral", bg: "bg-yellow-100" },
            { value: 4, key: "bad", bg: "bg-orange-100" },
            { value: 5, key: "very_bad", bg: "bg-red-100" }
          ].each do |mood| %>
            <label class="mood-option cursor-pointer" data-action="click->mood-selector#select">
              <%= form.radio_button :symptom_level, mood[:value],
                    class: "hidden mood-radio",
                    id: "mood_#{mood[:key]}",
                    data: { mood_selector_target: "radio" } %>

              <div class="mood-icon-wrapper flex flex-col items-center p-2 rounded-lg transition-all duration-200 hover:scale-105"
                   data-mood-selector-target="wrapper">
                <div class="mood-icon-circle w-12 h-12 rounded-full p-2 <%= mood[:bg] %>">
                  <%= render "mood_icons/#{mood[:key]}" %>
                </div>
              </div>
            </label>
          <% end %>
        </div>

        <div class="mt-6">
          <p class="text-ms text-gray-700 mt-0">一言日記 *任意 *100文字まで</p>
          <%= form.text_area :oneline_diary,
                placeholder: "晴れてて気分がよかった",
                maxlength: 100,
                rows: 3,
                class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>

        <div class="mt-6 text-center">
          <%= form.submit "日記を保存",
                class: "inline-block w-full text-center bg-gray-500 hover:bg-red-800 text-white py-3 px-4 rounded-md font-medium shadow transition-colors duration-200" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to '記録一覧を見る', diaries_path, class: "inline-block w-40 text-center bg-gray-500 hover:bg-red-800 text-white py-3 px-4 rounded-md font-medium shadow transition-colors duration-200" %>
    </div>
  </div>
</div>

<style>
  .mood-icon-wrapper.selected {
    transform: scale(1.05);
  }

  .mood-icon-wrapper.selected .mood-icon-circle {
    box-shadow: 0 0 0 3px #374151;
  }
</style>
